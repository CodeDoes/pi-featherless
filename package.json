{
  "name": "@codedoes/pi-featherless",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeDoes/pi-featherless"
  },
  "pi": {
    "extensions": [
      "./src/extensions/provider/index.ts",
      "./src/extensions/command-tokenize/index.ts",
      "./src/extensions/command-test-models/index.ts",
      "./src/extensions/command-test-inference/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "0.61.0",
    "@mariozechner/pi-tui": "0.61.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "prepare": "[ -d .git ] && husky || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@aliou/pi-utils-ui": "^0.1.2",
    "@codedoes/pi-featherless": "link:"
  },
  "optionalDependencies": {
    "@mariozechner/pi-ai": "link:../pi-mono/packages/ai"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@mariozechner/pi-coding-agent": "link:../pi-mono/packages/coding-agent",
    "@mariozechner/pi-tui": "link:../pi-mono/packages/coding-agent",
    "@sinclair/typebox": "^0.34.48",
    "@types/node": "^25.0.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@mariozechner/pi-ai": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-tui": "$@mariozechner/pi-coding-agent"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.26.1"
}
